@page "/"
@using System.Net.Http.Headers
@rendermode InteractiveServer
@inject ApiConfig ApiConfig
@inject HttpClient Http

<PageTitle>NetFrames - Home</PageTitle>

<div class="page-header">
    <h1>Photo Collection</h1>
    @if (selectedIds.Count > 0)
    {
        @if (GetVisibilityAction() is string action)
        {
            <button class="btn btn-outline-secondary btn-sm toggle-selected-btn" @onclick="ToggleSelectedVisibility" title="@action selected images">
                <i class="bi @(action == "Hide" ? "bi-eye-slash" : "bi-eye") me-1"></i> @action (@selectedIds.Count)
            </button>
        }
        <button class="btn btn-outline-danger btn-sm delete-selected-btn" @onclick="DeleteSelected" disabled="@isDeleting">
            @if (isDeleting)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            else
            {
                <i class="bi bi-trash me-1"></i>
            }
            Delete (@selectedIds.Count)
        </button>
    }
</div>

@if (isLoading)
{
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else
{
    <div class="image-grid">
        <div class="image-container upload-zone-grid @(isDragOver ? "drag-over" : "")"
             @ondragenter="OnDragEnter"
             @ondragover="OnDragOver"
             @ondragleave="OnDragLeave"
             @ondrop="OnDrop">

            @if (isUploading)
            {
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Uploading...</span>
                </div>
            }
            else
            {
                <i class="bi bi-plus-lg upload-grid-icon"></i>
                <span class="upload-grid-text">Add Photo</span>
            }

            <InputFile OnChange="OnInputFileChange" accept=".jpg,.jpeg" class="upload-input" />
        </div>

        @if (images?.Any() == true)
        {
            @foreach (var img in images)
            {
                var isSelected = selectedIds.Contains(img.Id);
                <div class="image-container @(isSelected ? "selected" : "") @(!img.Enabled ? "disabled" : "")">
                    <button class="select-btn @(isSelected ? "checked" : "")"
                            @onclick="() => ToggleSelect(img.Id)"
                            @onclick:stopPropagation
                            title="Select image">
                        <i class="bi @(isSelected ? "bi-check-circle-fill" : "bi-check-circle")"></i>
                    </button>
                    <img src="@($"{ApiConfig.BaseUrl}/images/{img.Id}")"
                         class="grid-image"
                         @onclick="() => ShowModal(img.Id)"
                         alt="Gallery image" />
                </div>
            }
        }
    </div>
}

@if (!string.IsNullOrEmpty(uploadStatus))
{
    <div class="toast-notification @(uploadSuccess ? "toast-success" : "toast-error")">
        <i class="bi @(uploadSuccess ? "bi-check-circle" : "bi-exclamation-triangle") me-2"></i>
        @uploadStatus
    </div>
}

@if (showModal)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div>
                <img
                    src="@($"{ApiConfig.BaseUrl}/images/{selectedId}")"
                    class="modal-image"
                    alt="Large view" />
            </div>

            @if (imageMetadata != null)
            {
                <div class="modal-metadata">
                    <span>@($"{imageMetadata.Width} x {imageMetadata.Height}")</span>
                    <span>@imageMetadata.UploadedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                </div>
            }

            <div style="display: flex; align-items: center; margin-top: 10px; width:100%">
                <p style="flex: 1; margin: 0; font-size: 0.8rem; color: var(--text-muted);">@(selectedId)@(imageMetadata?.Extension)</p>
                <button class="visibility-btn" @onclick="ToggleVisibility" title="@(IsSelectedEnabled() ? "Disable for clients" : "Enable for clients")">
                    <i class="bi @(IsSelectedEnabled() ? "bi-eye" : "bi-eye-slash")"></i>
                </button>
                <button class="trash-btn" @onclick="DeleteImage" title="Delete image" style="margin-left: 8px;">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isUploading;
    private bool isDeleting;
    private bool uploadSuccess;
    private bool isDragOver;
    private bool showModal = false;
    private string? selectedId;
    private string? uploadStatus;
    private List<ImageInfo>? images;
    private ImageMetadata? imageMetadata;
    private HashSet<string> selectedIds = new();

    private record ImageInfo(string Id, bool Enabled);
    private record ImageMetadata(string Extension, DateTime UploadedAt, int Width, int Height);

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            images = await Http.GetFromJsonAsync<List<ImageInfo>>($"{ApiConfig.BaseUrl}/images/list/all");
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool IsSelectedEnabled()
    {
        return images?.FirstOrDefault(i => i.Id == selectedId)?.Enabled ?? true;
    }

    private string? GetVisibilityAction()
    {
        if (images == null || selectedIds.Count == 0) return null;
        var selected = images.Where(i => selectedIds.Contains(i.Id)).ToList();
        bool hasEnabled = selected.Any(i => i.Enabled);
        bool hasDisabled = selected.Any(i => !i.Enabled);
        if (hasEnabled && hasDisabled) return null;
        return hasEnabled ? "Hide" : "Show";
    }

    private async Task ToggleVisibility()
    {
        if (selectedId is null) return;

        var response = await Http.PostAsync($"{ApiConfig.BaseUrl}/images/{selectedId}/toggle", null);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<ImageInfo>();
            if (result != null && images != null)
            {
                var index = images.FindIndex(i => i.Id == result.Id);
                if (index >= 0)
                    images[index] = result;
            }
            StateHasChanged();
        }
    }

    private async Task ToggleSelectedVisibility()
    {
        foreach (var id in selectedIds.ToList())
        {
            var response = await Http.PostAsync($"{ApiConfig.BaseUrl}/images/{id}/toggle", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ImageInfo>();
                if (result != null && images != null)
                {
                    var index = images.FindIndex(i => i.Id == result.Id);
                    if (index >= 0)
                        images[index] = result;
                }
            }
        }
        selectedIds.Clear();
        StateHasChanged();
    }

    private void ToggleSelect(string id)
    {
        if (!selectedIds.Remove(id))
            selectedIds.Add(id);
    }

    private async Task DeleteSelected()
    {
        if (selectedIds.Count == 0) return;

        isDeleting = true;
        var toDelete = selectedIds.ToList();
        var deletedCount = 0;

        foreach (var id in toDelete)
        {
            var response = await Http.DeleteAsync($"{ApiConfig.BaseUrl}/images/{id}");
            if (response.IsSuccessStatusCode)
            {
                images?.RemoveAll(i => i.Id == id);
                selectedIds.Remove(id);
                deletedCount++;
            }
        }

        isDeleting = false;
        uploadSuccess = true;
        uploadStatus = $"{deletedCount} image{(deletedCount != 1 ? "s" : "")} deleted.";
        _ = DismissToastAfterDelay();
    }

    private void OnDragEnter() => isDragOver = true;
    private void OnDragOver() => isDragOver = true;
    private void OnDragLeave() => isDragOver = false;
    private void OnDrop() => isDragOver = false;

    private CancellationTokenSource? toastCts;

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        uploadStatus = null;

        if (!file.ContentType.StartsWith("image/"))
        {
            uploadStatus = "Please select a valid image file.";
            uploadSuccess = false;
            _ = DismissToastAfterDelay();
            return;
        }

        isUploading = true;
        StateHasChanged();

        try
        {
            using var fileData = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(fileData);
            fileData.Position = 0;

            using var content = new MultipartFormDataContent();
            var streamContent = new StreamContent(fileData);
            streamContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            content.Add(streamContent, "image", file.Name);

            var response = await Http.PostAsync($"{ApiConfig.BaseUrl}/images/upload", content);
            if (response.IsSuccessStatusCode)
            {
                uploadStatus = "Image uploaded successfully!";
                uploadSuccess = true;
                images = await Http.GetFromJsonAsync<List<ImageInfo>>($"{ApiConfig.BaseUrl}/images/list/all");
            }
            else
            {
                uploadStatus = $"Upload failed: {await response.Content.ReadAsStringAsync()}";
                uploadSuccess = false;
            }
        }
        catch (Exception ex)
        {
            uploadStatus = $"Error: {ex.Message}";
            uploadSuccess = false;
        }
        finally
        {
            isUploading = false;
            _ = DismissToastAfterDelay();
        }
    }

    private async Task DismissToastAfterDelay()
    {
        toastCts?.Cancel();
        toastCts = new CancellationTokenSource();
        var token = toastCts.Token;

        try
        {
            await Task.Delay(4000, token);
            uploadStatus = null;
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private async Task ShowModal(string id)
    {
        selectedId = id;
        imageMetadata = null;
        showModal = true;
        try
        {
            imageMetadata = await Http.GetFromJsonAsync<ImageMetadata>($"{ApiConfig.BaseUrl}/images/{id}/info");
        }
        catch { }
        StateHasChanged();
    }

    private async Task DeleteImage()
    {
        if (selectedId is null)
            return;

        var response = await Http.DeleteAsync($"{ApiConfig.BaseUrl}/images/{selectedId}");
        if (response.IsSuccessStatusCode)
        {
            images?.RemoveAll(i => i.Id == selectedId);
            selectedIds.Remove(selectedId);
            showModal = false;
            StateHasChanged();
        }
    }

    private void CloseModal()
    {
        showModal = false;
    }
}
